# Logs and temporary files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# SQLite (safety if someone switches DB locally)
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-[0-9]*

# Environment files
.env
.env*.local

# Bundler
/.bundle
/vendor/bundle

# Node
node_modules/

# Yarn (classic compatibility)
.yarn-integrity

# Built assets
/public/assets

# ActiveStorage
/storage/*
!/storage/.keep
/public/uploads

# Rails credentials
/config/*.key
/config/credentials/*.key
config/master.key

# IDE / editors
.ruby-lsp/
.vscode/
.idea/

# macOS
.DS_Store

# Ruby REPL history
.pry_history
.irb_history

# Test coverage
coverage/
